# ── Telegram ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=tu_token_aqui
ADMIN_CHAT_ID=-100xxxxxxxxx          # ID del chat/grupo de administradores

# ── Google Gemini (gratis en aistudio.google.com) ───────────────────
GEMINI_API_KEY=tu_key_aqui

# ── Railway Redis (Railway lo inyecta automáticamente) ──────────────
REDIS_URL=redis://localhost:6379

# ── Base de datos ───────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./vzla_bot.db
# Para producción en Railway usa PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname

# ── Control de presupuesto Gemini ───────────────────────────────────
GEMINI_DAILY_TOKEN_LIMIT=800000
GEMINI_DAILY_REQUEST_LIMIT=1200
GEMINI_RPM_LIMIT=12

# ── Worker ──────────────────────────────────────────────────────────
WORKER_CONCURRENCY=3
MAX_VIDEO_DURATION_MIN=10
MAX_VIDEO_SIZE_MB=200

# ── Mini App ────────────────────────────────────────────────────────
MINIAPP_URL=https://tu-proyecto.railway.app
API_PORT=8000

# ── Entorno ─────────────────────────────────────────────────────────
ENVIRONMENT=development    # development | production
LOG_LEVEL=INFO
